<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <add key="ServerBaseUrl" value="https://ypn.obba.ai" />
        <add key="AgentName" value="EageSoop-Agent" />
        <add key="HeartbeatIntervalMs" value="5000" />
        <add key="StatusReportIntervalMs" value="3000" />
        <!-- true：注册成功后走 WebSocket（省 HTTP 轮询）；false：仅用原有 HTTP 轮询 -->
        <add key="UseAgentWebSocket" value="true" />
    </appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>